# Backend Environment Variables
# Copy this file to .env for local development

# Include frontend URLs and any other services that need access
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:7000

# Prompted Segmentation Service URL
# Update this to match where coral-prompted-seg is running
# For local development:
PROMPTED_SEGMENTATION_BACKEND_URL=http://localhost:8001
# For Docker network:
# PROMPTED_SEGMENTATION_BACKEND_URL=http://coral-prompted-seg:8001

# Automatic Segmentation Service URL  
# Update this to match where coral-automatic-seg is running
# For local development:
AUTOMATIC_SEGMENTATION_BACKEND_URL=http://localhost:8002
# For Docker network:
# AUTOMATIC_SEGMENTATION_BACKEND_URL=

# For production deployment with external network:
# ALLOWED_ORIGINS=https://coral.ni.dfki.de,http://localhost:3000
# PROMPTED_SEGMENTATION_BACKEND_URL=
# AUTOMATIC_SEGMENTATION_BACKEND_URL=

